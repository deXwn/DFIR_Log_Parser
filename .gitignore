# -------------------------------------------------------------------
# DFIR Suite - Privacy-first ignore rules
# Goal: never commit local logs, databases, exports, credentials,
# machine-specific artifacts, or incident/customer data from this repo.
# -------------------------------------------------------------------

# Runtime logs / pids
logs/
*.log
*.pid
*.pid.lock
*.seed

# SQLite / DB artifacts
*.db
*.db-*
*.sqlite
*.sqlite-*
*.sqlite3
*.sqlite3-*
*.mdb
*.ldb

# DFIR case data
*.evtx
*.evt
*.pcap
*.pcapng
*.etl
*.dmp
*.core
*.mem
*.raw
*.vhd
*.vhdx
*.E01
*.e01

# Archives often carrying customer or incident data
*.zip
*.7z
*.rar
*.tar
*.gz
*.bz2
*.xz
*.tgz

# Secrets / local env / certificates
.env
.env.*
.envrc
*.local
*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
*.kdbx
*.ovpn
id_rsa
id_ed25519
*.pub

# Python cache
__pycache__/
*.pyc
*.pyo

# Editor / OS junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.temp

# Rust
**/target/
**/*.rs.bk

# Node / Next / frontend build caches
**/node_modules/
**/.next/
**/.turbo/
**/.vercel/
**/dist/
**/build/
**/coverage/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tool output / generated artifacts
apps/Log_parser/exports/*
!apps/Log_parser/exports/.gitkeep
apps/Log_parser/exports_local/*
!apps/Log_parser/exports_local/.gitkeep
apps/Log_parser/log/*
!apps/Log_parser/log/.gitkeep
apps/EventLogParser/event_log/
apps/EventLogParser/events.db
apps/EventLogParser/events.db-shm
apps/EventLogParser/events.db-wal
apps/Log_parser/detections.sqlite

# Local caches
.cache/
.pytest_cache/
